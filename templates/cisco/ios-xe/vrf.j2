{# templates/cisco/ios-xe/vrf.j2
   Renders VRF configuration for Cisco IOS-XE
   Variables injected by the resolution service via the normalized VrfPrimitive object
#}

{# ── VRF Definition ───────────────────────────────────────────────────── #}
vrf definition {{ vrf_name }}
 rd {{ route_distinguisher }}
 description {{ description | truncate(200, True, '') }}
 !
 address-family ipv4
  route-target export {{ rt_export }}
  route-target import {{ rt_import }}
  {% if additional_rt_imports is defined %}
  {% for rt in additional_rt_imports %}
  route-target import {{ rt }}
  {% endfor %}
  {% endif %}
 exit-address-family
 !
 {% if ipv6_enabled is defined and ipv6_enabled %}
 address-family ipv6
  route-target export {{ rt_export_v6 }}
  route-target import {{ rt_import_v6 }}
 exit-address-family
 !
 {% endif %}
!

{# ── BGP VRF Address Family ───────────────────────────────────────────── #}
{% if bgp_asn is defined %}
router bgp {{ bgp_asn }}
 !
 address-family ipv4 vrf {{ vrf_name }}
  {% if redistribute_connected %}
  redistribute connected
  {% endif %}
  {% if redistribute_static %}
  redistribute static
  {% endif %}
  {% for neighbor in bgp_neighbors %}
  neighbor {{ neighbor.ip }} remote-as {{ neighbor.remote_asn }}
  neighbor {{ neighbor.ip }} description {{ neighbor.description }}
  neighbor {{ neighbor.ip }} activate
  {% if neighbor.route_map_in is defined %}
  neighbor {{ neighbor.ip }} route-map {{ neighbor.route_map_in }} in
  {% endif %}
  {% if neighbor.route_map_out is defined %}
  neighbor {{ neighbor.ip }} route-map {{ neighbor.route_map_out }} out
  {% endif %}
  neighbor {{ neighbor.ip }} send-community both
  {% endfor %}
 exit-address-family
 !
{% endif %}

{# ── ACL for Isolation ────────────────────────────────────────────────── #}
{% if acl_entries is defined %}
ip access-list extended ACL-{{ vrf_name }}-INGRESS
 remark === Generated by intent {{ intent_id }} v{{ intent_version }} ===
 remark === DO NOT EDIT MANUALLY - managed by network-as-code ===
 {% for entry in acl_entries %}
 {% if entry.action == 'deny' %}
 deny {{ entry.protocol }} {{ entry.source }} {{ entry.destination }} log
 {% else %}
 permit {{ entry.protocol }} {{ entry.source }} {{ entry.destination }}
 {% endif %}
 {% endfor %}
 permit ip any any
!
{% endif %}

{# ── QoS Policy Map Assignment ────────────────────────────────────────── #}
{% if qos_class is defined %}
{# QoS policy maps are pre-defined globally - we just apply the right one #}
{% set qos_map = {
    'critical-business': 'PM-CRITICAL-BUSINESS',
    'standard-business': 'PM-STANDARD-BUSINESS',
    'best-effort': 'PM-BEST-EFFORT'
} %}
{# Applied on the interface level - reference only here #}
! QoS: Apply policy-map {{ qos_map[qos_class] }} to VRF {{ vrf_name }} interfaces
{% endif %}
