{# templates/cisco/ios-xe/bgp_neighbor.j2
   Adds/removes BGP neighbor in a VRF context
#}

router bgp {{ local_asn }}
 !
 address-family ipv4 vrf {{ vrf_name }}
  !
  {# ── Neighbor Statement ─────────────────────────────────────── #}
  neighbor {{ neighbor_ip }} remote-as {{ neighbor_asn }}
  neighbor {{ neighbor_ip }} description {{ neighbor_description }}
  neighbor {{ neighbor_ip }} update-source {{ update_source_interface }}
  neighbor {{ neighbor_ip }} activate
  neighbor {{ neighbor_ip }} send-community both
  {% if bfd_enabled is defined and bfd_enabled %}
  neighbor {{ neighbor_ip }} fall-over bfd
  {% endif %}
  {% if next_hop_self is defined and next_hop_self %}
  neighbor {{ neighbor_ip }} next-hop-self
  {% endif %}
  !
  {# ── Route Maps ─────────────────────────────────────────────── #}
  {% if route_map_in is defined %}
  neighbor {{ neighbor_ip }} route-map {{ route_map_in }} in
  {% endif %}
  {% if route_map_out is defined %}
  neighbor {{ neighbor_ip }} route-map {{ route_map_out }} out
  {% endif %}
  !
  {# ── Timers (optional override) ─────────────────────────────── #}
  {% if keepalive_timer is defined and hold_timer is defined %}
  neighbor {{ neighbor_ip }} timers {{ keepalive_timer }} {{ hold_timer }}
  {% endif %}
  !
  {# ── Maximum Prefix Limit ────────────────────────────────────── #}
  {% if max_prefix is defined %}
  neighbor {{ neighbor_ip }} maximum-prefix {{ max_prefix }} 80 warning-only
  {% endif %}
  !
 exit-address-family
!
