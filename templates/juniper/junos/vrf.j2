{# templates/juniper/junos/vrf.j2
   Renders routing-instance (VRF equivalent) for Juniper JunOS
   Uses set-style commands for easier diffing
#}

{# ── Routing Instance ─────────────────────────────────────────────────── #}
set routing-instances {{ vrf_name }} instance-type vrf
set routing-instances {{ vrf_name }} description "{{ description | truncate(200, True, '') }}"
set routing-instances {{ vrf_name }} route-distinguisher {{ route_distinguisher }}
set routing-instances {{ vrf_name }} vrf-target target:{{ rt_export }}

{% if additional_rt_imports is defined %}
{% for rt in additional_rt_imports %}
set routing-instances {{ vrf_name }} vrf-import target:{{ rt }}
{% endfor %}
{% endif %}

{# ── VRF Table Label ──────────────────────────────────────────────────── #}
set routing-instances {{ vrf_name }} vrf-table-label

{# ── Interface Assignments ────────────────────────────────────────────── #}
{% for interface in vrf_interfaces %}
set routing-instances {{ vrf_name }} interface {{ interface }}
{% endfor %}

{# ── BGP in Routing Instance ──────────────────────────────────────────── #}
{% if bgp_neighbors is defined %}
set routing-instances {{ vrf_name }} protocols bgp group {{ vrf_name }}-PEERS type external
set routing-instances {{ vrf_name }} protocols bgp group {{ vrf_name }}-PEERS export {{ vrf_name }}-EXPORT
set routing-instances {{ vrf_name }} protocols bgp group {{ vrf_name }}-PEERS import {{ vrf_name }}-IMPORT
{% for neighbor in bgp_neighbors %}
set routing-instances {{ vrf_name }} protocols bgp group {{ vrf_name }}-PEERS neighbor {{ neighbor.ip }} peer-as {{ neighbor.remote_asn }}
set routing-instances {{ vrf_name }} protocols bgp group {{ vrf_name }}-PEERS neighbor {{ neighbor.ip }} description "{{ neighbor.description }}"
{% endfor %}
{% endif %}

{# ── Firewall Filter (ACL equivalent) ─────────────────────────────────── #}
{% if acl_entries is defined %}
{% for entry in acl_entries %}
{% if entry.action == 'deny' %}
set firewall family inet filter FF-{{ vrf_name }}-INGRESS term DENY-{{ loop.index }} from source-address {{ entry.source }}
set firewall family inet filter FF-{{ vrf_name }}-INGRESS term DENY-{{ loop.index }} from destination-address {{ entry.destination }}
set firewall family inet filter FF-{{ vrf_name }}-INGRESS term DENY-{{ loop.index }} then discard
set firewall family inet filter FF-{{ vrf_name }}-INGRESS term DENY-{{ loop.index }} then count DENY-{{ loop.index }}-COUNT
{% endif %}
{% endfor %}
set firewall family inet filter FF-{{ vrf_name }}-INGRESS term PERMIT-ALL then accept
{% endif %}

{# ── Routing Policy ───────────────────────────────────────────────────── #}
set policy-options policy-statement {{ vrf_name }}-EXPORT term BGP from protocol bgp
set policy-options policy-statement {{ vrf_name }}-EXPORT term BGP then community add {{ vrf_name }}-COMMUNITY
set policy-options policy-statement {{ vrf_name }}-EXPORT term BGP then accept
set policy-options policy-statement {{ vrf_name }}-EXPORT term DIRECT from protocol direct
set policy-options policy-statement {{ vrf_name }}-EXPORT term DIRECT then accept

{% if bgp_community is defined %}
set policy-options community {{ vrf_name }}-COMMUNITY members {{ bgp_community }}
{% endif %}
